# Copier vers .env (non versionne) et renseigner les valeurs. Charger les variables dans l'IDE ou Docker.

DB_URL=jdbc:postgresql://localhost:5433/forsalaw
DB_USERNAME=forsalaw
DB_PASSWORD=forsalaw

JWT_SECRET=replace_with_a_strong_secret_min_32_chars
JWT_EXPIRATION_MS=86400000

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH2_SUCCESS_REDIRECT_URI=http://localhost:4200/auth/google/callback

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password_or_app_password
MAIL_FROM=no-reply@forsalaw.com

# Reset mot de passe : base URL de la page /reset-password?token=... (besoin du frontend ; defaut 4200)
PASSWORD_RESET_FRONTEND_URL=http://localhost:4200/reset-password

# Notifications RDV : lien generique dans le mail (sans frontend : Swagger sur le port de l'API)
FRONTEND_BASE_URL=http://localhost:8081/swagger-ui.html

# Visio RDV en ligne (gratuit) : Jitsi public
JITSI_BASE_URL=https://meet.jit.si

# Email admin recevant les demandes de deblocage de compte
ADMIN_SUPPORT_EMAIL=admin@forsalaw.com

# Rappels RDV J-1 / H-1 (identifiant fuseau IANA)
NOTIFICATIONS_TIMEZONE=Africa/Tunis

# Optionnel
SERVER_PORT=8081
